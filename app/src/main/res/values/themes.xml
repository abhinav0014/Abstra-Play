<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.StreamSphere" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/background</item>
        <item name="android:statusBarColor">@color/background</item>
        <item name="android:navigationBarColor">@color/surface</item>
    </style>

    <style name="Theme.StreamSphere.Splash" parent="Theme.SplashScreen">
        <!-- Match your Lottie background color so there's no flash -->
        <item name="windowSplashScreenBackground">@color/background</item>
        <!-- Remove the static icon — Lottie handles the animation -->
        <item name="windowSplashScreenAnimatedIcon">@android:color/transparent</item>
        <item name="postSplashScreenTheme">@style/Theme.StreamSphere</item>
    </style>
</resources>
